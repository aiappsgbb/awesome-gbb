# =============================================================================
# CI infrastructure — environment variable template
# =============================================================================
#
# Copy this file to `.env.ci` (gitignored) and populate with the actual values
# from your CI subscription. The real values are stored in GitHub repo
# Secrets (Settings → Secrets and variables → Actions) and are NEVER
# committed to this repository.
#
# This template documents the contract — it is committed to the repo as a
# reference, but real values stay local.
#
# Usage:
#   1. Get the real values from a maintainer or 1Password / Key Vault.
#   2. Copy template to `.env.ci`:    cp .env.ci.example .env.ci
#   3. Edit `.env.ci` and fill in the values (it's gitignored).
#   4. Source before running local E2E:    set -a; source .env.ci; set +a
#
# CI (GitHub Actions) populates these from repo Secrets automatically — you
# only need this file for local manual E2E runs.
# =============================================================================


# -----------------------------------------------------------------------------
# OIDC authentication (Azure AD)
# -----------------------------------------------------------------------------
# These three identify the CI workload identity that GitHub Actions uses to
# auth into Azure via OIDC federated credentials. Available as repo secrets
# of the same name.

AZURE_TENANT_ID=<entra-tenant-guid>
AZURE_SUBSCRIPTION_ID=<ci-subscription-guid>
AZURE_CLIENT_ID=<ci-uami-client-id>
AZURE_LOCATION=<azure-region>

# Object IDs used only when reprovisioning the standing foundry-iq Search
# service through skills/foundry-iq/test-fixture/azure.yaml. These are ARM
# role-assignment principal IDs, not application/client IDs.
FOUNDRY_IQ_RESOURCE_GROUP=rg-foundry-iq-<suffix>
AZURE_PRINCIPAL_ID=<provisioner-object-id>
CI_PRINCIPAL_ID=<ci-uami-object-id>


# -----------------------------------------------------------------------------
# Foundry / AI Services
# -----------------------------------------------------------------------------
# Endpoint of the AI Services (Foundry) account that hosts the model
# deployment used for both E2E skill tests and the Copilot CLI driver
# (COPILOT_PROVIDER_BASE_URL).

AZURE_AI_ENDPOINT=https://<ci-foundry-account>.cognitiveservices.azure.com/


# Full Foundry project endpoint used by skills that target a specific
# project under the AI Services account (e.g. memory, prompt-agents).

FOUNDRY_PROJECT_ENDPOINT=https://<ci-foundry-account>.services.ai.azure.com/api/projects/<ci-project-name>


# -----------------------------------------------------------------------------
# Container Registry / Container Apps
# -----------------------------------------------------------------------------

ACR_LOGIN_SERVER=<ci-container-registry>.azurecr.io


# -----------------------------------------------------------------------------
# Observability (optional — only needed by skills that query LAW directly)
# -----------------------------------------------------------------------------

LAW_WORKSPACE_ID=<law-workspace-guid>
APPLICATIONINSIGHTS_CONNECTION_STRING=<app-insights-connection-string>


# =============================================================================
# Discovery vars (used by docs / scripts that reference CI resources by name)
# =============================================================================
# These are NOT consumed by workflows — they exist so that AGENTS.md,
# README.md, and helper scripts can interpolate placeholder names without
# hardcoding them in source files. Leave as `<placeholder>` for the template;
# fill in concrete names for local-dev convenience.

CI_LOCATION=<azure-region>                         # e.g. swedencentral
CI_RESOURCE_GROUP=<ci-resource-group>              # the persistent E2E RG
CI_FOUNDRY_ACCOUNT=<ci-foundry-account>            # AI Services account name
CI_FOUNDRY_PROJECT=<ci-foundry-project>            # Foundry project under the account
CI_CONTAINER_REGISTRY=<ci-container-registry>      # ACR name (without .azurecr.io)
CI_CONTAINER_APP_ENV=<ci-container-app-env>        # ACA managed environment
CI_UAMI_NAME=<ci-uami-name>                        # User-Assigned Managed Identity
CI_MODEL_DEPLOYMENT=<model-deployment-name>        # e.g. gpt-5.4-mini
CI_EMBEDDING_DEPLOYMENT=<embedding-deployment>     # e.g. text-embedding-3-small
