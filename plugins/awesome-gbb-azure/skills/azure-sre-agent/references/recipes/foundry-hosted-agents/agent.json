{
  "_scenario": "foundry-hosted-agents",
  "_description": "SRE Agent pre-wired to investigate Foundry hosted-agent operations (BYOK 401s, deploy failures, quota throttles).",
  "_prerequisites": [
    "Azure subscription with Microsoft.App RP registered",
    "Foundry project deployed with at least one hosted agent",
    "Foundry App Insights and Log Analytics workspace ARM IDs"
  ],
  "_prompts": {
    "agentName": {
      "ask": "Agent name",
      "default": "sre-foundry-pilot"
    },
    "resourceGroup": {
      "ask": "Resource group for the agent",
      "default": "rg-sre-foundry-pilot"
    },
    "location": {
      "ask": "Region",
      "options": ["eastus2", "swedencentral", "uksouth", "australiaeast"],
      "required": true
    },
    "targetRGs": {
      "ask": "Resource groups to monitor (include the Foundry project's RG)",
      "required": true
    },
    "foundryAppInsightsId": {
      "ask": "ARM ID of the Foundry App Insights resource",
      "required": true
    },
    "foundryLawId": {
      "ask": "ARM ID of the Foundry Log Analytics workspace",
      "required": true
    },
    "existingUamiId": {
      "ask": "Existing UAMI resource ID (leave blank to create new)",
      "default": ""
    }
  },
  "identity": {
    "agentName": "{{agentName}}",
    "resourceGroup": "{{resourceGroup}}",
    "subscription": "",
    "location": "{{location}}",
    "targetResourceGroups": "{{targetRGs}}"
  },
  "access": {
    "accessLevel": "Low",
    "actionMode": "Review"
  },
  "upgradeChannel": "Preview",
  "defaultModelProvider": "Azure OpenAI",
  "monthlyAgentUnitLimit": 10000,
  "tags": {
    "gbb-recipe": "foundry-hosted-agents",
    "gbb-source": "aiappsgbb/awesome-gbb/azure-sre-agent"
  },
  "toggles": {
    "enableAppInsightsConnector": true,
    "appInsightsResourceId": "{{foundryAppInsightsId}}",
    "enableLogAnalyticsConnector": true,
    "lawResourceId": "{{foundryLawId}}"
  },
  "existingUamiId": "{{existingUamiId}}",
  "existingAgentAppInsightsId": "{{foundryAppInsightsId}}"
}
