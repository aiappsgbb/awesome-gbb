// Default Azure Log Analytics query for Streamlit PAYGO vs PTU analysis
// Required output schema:
// - minute_bin (datetime)
// - input_tokens_sum (int)
// - cached_tokens_sum (int)
// - output_tokens_sum (int)

let startTime = ago(__TIME_RANGE__);
let window = 1m;
AzureMetrics
| where TimeGenerated >= startTime
| where ResourceProvider == "MICROSOFT.COGNITIVESERVICES"
| where MetricName in ("InputTokens", "ProcessedPromptTokens", "GeneratedTokens")
| extend model_dims = parse_json(tostring(coalesce(column_ifexists("DimensionJson", ""), column_ifexists("Dimensions", ""), column_ifexists("Tags", ""), "{}")))
| extend ModelDeploymentName = tostring(model_dims.ModelDeploymentName)
| extend metric_value = todouble(coalesce(Total, Average, Maximum, Minimum, Count))
__DEPLOYMENT_FILTER__
| summarize
    input_tokens_sum = sumif(metric_value, MetricName == "InputTokens"),
    processed_prompt_tokens_sum = sumif(metric_value, MetricName == "ProcessedPromptTokens"),
    output_tokens_sum = sumif(metric_value, MetricName == "GeneratedTokens")
    by minute_bin = bin(TimeGenerated, window)
| extend
    input_tokens_sum = todouble(coalesce(input_tokens_sum, 0.0)),
    processed_prompt_tokens_sum = todouble(coalesce(processed_prompt_tokens_sum, 0.0)),
    output_tokens_sum = toint(coalesce(output_tokens_sum, 0.0))
| extend
    input_tokens_sum = toint(input_tokens_sum),
    cached_tokens_sum = toint(max_of(input_tokens_sum - processed_prompt_tokens_sum, 0.0))
| project
    minute_bin,
    input_tokens_sum,
    cached_tokens_sum,
    output_tokens_sum
| order by minute_bin asc
