# Local-test environment file template.
# Copy to <poc-root>/.env.local and edit; .env.local is gitignored.
#
# Used by:
#   - tests/local_smoke.py + local_smoke_oneshot.py (Pattern 2)
#   - docker compose -f references/local-stack/compose.local.yaml (Pattern 3)
#   - tests/seed_local_cosmos.py

# --- AOAI / Foundry --------------------------------------------------
# Pick ONE: Foundry (preferred — same client class as prod) OR AOAI direct.

FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# OR (AOAI direct fallback, if you have no Foundry):
# AZURE_OPENAI_ENDPOINT=https://<your-aoai-account>.openai.azure.com
# AZURE_OPENAI_API_KEY=<key-or-use-DefaultAzureCredential>
# MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# --- Local MCP server ------------------------------------------------
MCP_SERVER_FQDN=localhost:8000
MCP_SERVER_URL=http://localhost:8000/mcp

# --- Local Cosmos emulator -------------------------------------------
# Default credentials — public + universally known for the emulator
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_DATABASE=<poc-name>-local
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_VERIFY_SSL=false

# --- AI Search (optional — leave blank to use mock_search.py) ---------
# SEARCH_ENDPOINT=https://<your-dev-search>.search.windows.net
# SEARCH_API_KEY=<key>
# Or set USE_MOCK_SEARCH=1 to load mock_search.py
USE_MOCK_SEARCH=1
MOCK_SEARCH_CORPUS=tests/sample-data/search-corpus.json

# --- KB names (same shape as agent.yaml in prod) ---------------------
KB_REG_EZ=kb-reg-ez-corpus
KB_NETWORK_RULES=kb-network-rules

# --- Logging --------------------------------------------------------
LOG_LEVEL=DEBUG
PYTHONUNBUFFERED=1
