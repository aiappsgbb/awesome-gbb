# --- LLM backend (pick one) -----------------------------------------------
# Default: Foundry project (matches prod parity with foundry-hosted-agents).
LLM_BACKEND=foundry
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Alternative: Azure OpenAI deployment (no Foundry project required).
# LLM_BACKEND=aoai
# AZURE_OPENAI_ENDPOINT=https://<your-aoai-account>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# Alternative: GitHub Models (no Azure required at all).
# Uses GITHUB_TOKEN for auth — get one via `gh auth token` or a PAT with `models` scope.
# Models prefixed with provider: openai/gpt-4o, meta/llama-3, etc.
# Rate-limited; suitable for local dev/demo only, not production loads.
# LLM_BACKEND=copilot
# GITHUB_TOKEN=<your-github-pat-or-gh-auth-token>
# COPILOT_MODEL=openai/gpt-4o

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO

# --- Azure auth -----------------------------------------------------------
# Quickstart uses DefaultAzureCredential, which honours AZURE_CONFIG_DIR.
# Set AZURE_CONFIG_DIR via your tenant index (see azure-tenant-isolation
# skill) BEFORE launching, so you can't accidentally use the wrong sub.
# AZURE_CONFIG_DIR=~/.azure-tenants/dev
