// agent-traces.kql
// Hosted-agent traces for the last hour, filtered to the agent runtime
// cloud roles (AgentService-* — the platform-managed identity-based names).
//
// Useful for: tracing a specific agent invocation by correlation_id,
// debugging which tools the agent called and why, watching streaming
// progress on long-running invocations.

let window = 1h;
traces
| where timestamp > ago(window)
| where cloud_RoleName startswith "AgentService-" or cloud_RoleName startswith "Foundry-"
| extend
    gen_ai_system    = tostring(customDimensions['gen_ai.system']),
    gen_ai_operation = tostring(customDimensions['gen_ai.operation.name']),
    gen_ai_model     = tostring(customDimensions['gen_ai.request.model']),
    gen_ai_in_tokens  = toint(customDimensions['gen_ai.usage.input_tokens']),
    gen_ai_out_tokens = toint(customDimensions['gen_ai.usage.output_tokens']),
    correlation_id   = tostring(customDimensions['correlation_id'])
| project
    timestamp,
    severityLevel,
    gen_ai_system,
    gen_ai_operation,
    gen_ai_model,
    gen_ai_in_tokens,
    gen_ai_out_tokens,
    correlation_id,
    message
| order by timestamp desc
| take 200
