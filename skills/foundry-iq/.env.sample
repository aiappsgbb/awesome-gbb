# Environment variables for Foundry IQ skill
#
# Copy this file to .env and fill in your values
# Install dependencies: pip install -r requirements.txt
#
# Auth: DefaultAzureCredential (keyless) is used by default.
# Threadlight pilots are KEYLESS-BY-MANDATE — do NOT set the *_KEY vars
# below in a deployed environment. Local-dev only.

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=            # Optional — omit for keyless auth (DefaultAzureCredential)
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# Azure AI Search Configuration
AI_SEARCH_ENDPOINT=https://<service>.search.windows.net
# AI_SEARCH_KEY=                    # Optional — omit for keyless auth (DefaultAzureCredential)
# Pin to match the endpoint surface you use:
#   2025-01-01-preview → /agents/<name>             (legacy)
#   2025-11-01-preview → /knowledgebases/<name>     (new)
AI_SEARCH_API_VERSION=2025-01-01-preview

# PolicyBot Configuration
POLICY_INDEX_NAME=policy-documents
POLICY_AGENT_NAME=policy-agent
POLICY_CHAT_MODEL=gpt-5.4-mini

# Document Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Agentic Retrieval — wire format is camelCase
REASONING_EFFORT=medium
OUTPUT_MODE=extractiveData

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8001
