# ============================================================================
# pilot-quickstart.env — cheapest demo of the Citadel Governance Hub
# ============================================================================
#
# Use case: 1-2 day demo / PoC. You want every API surface working with the
# minimum possible spend and the simplest networking shape so notebooks can
# hit the gateway from the open internet without VPN setup.
#
# What you get:
#   - APIM Developer SKU (cheap, ~$50/mo, NO SLA, NOT for production)
#   - Public APIM gateway (api.azure-api.net) — easy to test from anywhere
#   - Greenfield VNet 10.170.0.0/24 + new private DNS zones in same RG
#   - All security feature flags ON (PII, content safety, realtime, unified-ai)
#   - Greenfield Log Analytics + 3 App Insights workspaces
#   - 2× Foundry instances (sweden + east-us-2) with upstream-default model list
#   - Managed Redis enabled (semantic caching layer)
#   - API Center disabled (cuts cost)
#
# Ballpark monthly cost: $200-400 with light usage (APIM Developer is the
# main fixed cost; Foundry token burn dominates above light usage).
#
# Apply: see SKILL.md § 5 Path A
# ============================================================================

# --- Basics ---
AZURE_LOCATION=swedencentral
APIC_LOCATION=swedencentral

# --- APIM (Developer SKU = cheapest) ---
APIM_SKU=Developer
APIM_SKU_UNITS=1
APIM_NETWORK_TYPE=External
APIM_V2_USE_PRIVATE_ENDPOINT=false
APIM_V2_PUBLIC_NETWORK_ACCESS=true

# --- Networking: greenfield ---
USE_EXISTING_VNET=false
USE_EXISTING_LOG_ANALYTICS=false
VNET_ADDRESS_PREFIX=10.170.0.0/24

# --- Backend services: keep public for easy demo (NOT production posture) ---
COSMOS_DB_PUBLIC_ACCESS=Enabled
AI_FOUNDRY_EXTERNAL_NETWORK_ACCESS=Enabled
KEY_VAULT_EXTERNAL_NETWORK_ACCESS=Enabled
EVENTHUB_NETWORK_ACCESS=Enabled
REDIS_PUBLIC_NETWORK_ACCESS=Enabled

# --- Capacity (low) ---
COSMOS_DB_RUS=400
EVENTHUB_CAPACITY=1
LOGIC_APPS_SKU_CAPACITY_UNITS=1

# --- Feature flags: enable everything that proves the pitch ---
ENABLE_PII_REDACTION=true
ENABLE_AI_MODEL_INFERENCE=true
ENABLE_OPENAI_REALTIME=true
ENABLE_UNIFIED_AI_API=true
ENABLE_MANAGED_REDIS=true
ENABLE_API_CENTER=false
ENABLE_AZURE_AI_SEARCH=false
ENABLE_DOCUMENT_INTELLIGENCE=false

# --- Auth: skip for demo (add JWT later via entra-id-setup) ---
AZURE_ENTRA_AUTH=false

# --- Dashboards: skip (cuts cost; rebuild after deploy if needed) ---
CREATE_DASHBOARDS=false

# --- SKUs ---
APIC_SKU=Free
KEY_VAULT_SKU_NAME=standard
REDIS_SKU_NAME=Balanced_B1
REDIS_SKU_CAPACITY=1
