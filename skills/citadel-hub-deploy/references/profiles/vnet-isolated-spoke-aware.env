# ============================================================================
# vnet-isolated-spoke-aware.env — Citadel Hub for hub-spoke landing zones
# ============================================================================
#
# Use case: deploy the Citadel Governance Hub into an existing hub-spoke
# topology. BYO VNet (peers to your landing zone hub VNet), BYO Private
# DNS Zones (typically central DNS in a separate sub), pre-wired so spokes
# deployed via the `foundry-vnet-deploy` skill can resolve the hub APIM
# private FQDN.
#
# What you get:
#   - APIM Standard v2 + private endpoint (no public gateway)
#   - Hub VNet pre-existing (USE_EXISTING_VNET=true)
#   - Private DNS Zones pre-existing in central DNS sub
#   - All backend services PRIVATE
#   - Foundry network injection enabled (agent subnet integration)
#   - 2× Foundry instances
#   - Managed Redis (semantic caching, private)
#
# Ballpark monthly cost: similar to enterprise-baseline ($800-2,500/mo)
# but ZERO public gateway exposure.
#
# REQUIRED before applying:
#   1. Pre-existing VNet with 4 subnets (apim, pe, functionapp, agents)
#      sized at least /26 each. Names must match the SUBNET_NAME env vars
#      below (or accept the snet-* defaults if you re-create the subnets
#      with those names).
#   2. Pre-existing 13 Private DNS Zones in a known RG/sub. Set the
#      EXISTING_DNS_ZONE_* env vars to FULL ARM RESOURCE IDs of each zone
#      (see commands at the bottom of this file).
#   3. Cross-sub `Network Contributor` granted to the deploying identity
#      on the BYO VNet RG and DNS RG.
#
# Apply: see SKILL.md § 5 Path C
# ============================================================================

# --- Basics ---
AZURE_LOCATION=swedencentral
APIC_LOCATION=swedencentral

# --- APIM (Standard v2 + private only) ---
APIM_SKU=StandardV2
APIM_SKU_UNITS=1
APIM_NETWORK_TYPE=External
APIM_V2_USE_PRIVATE_ENDPOINT=true
APIM_V2_PUBLIC_NETWORK_ACCESS=false
# ^^ FULLY PRIVATE — spokes must reach the hub via VNet peering + DNS
# zone link, NOT public DNS.

# --- Networking: BYO VNet ---
USE_EXISTING_VNET=true
# Set at call site (org-specific):
#   azd env set VNET_NAME       "vnet-citadel-hub"
#   azd env set EXISTING_VNET_RG "rg-network-prod"

# Subnet names default to snet-{apim,private-endpoint,functionapp,agents}
# Override only if your existing VNet uses different subnet names:
# APIM_SUBNET_NAME=snet-apim
# PRIVATE_ENDPOINT_SUBNET_NAME=snet-private-endpoint
# FUNCTION_APP_SUBNET_NAME=snet-functionapp
# AGENT_SUBNET_NAME=snet-agents

# --- BYO Private DNS Zones (org-specific — set at call site) ---
# All 13 zones must be set; example pattern:
#
# DNS_RG=rg-dns-prod
# DNS_SUB=<central-dns-sub-id>
# BASE="/subscriptions/$DNS_SUB/resourceGroups/$DNS_RG/providers/Microsoft.Network/privateDnsZones"
#
# azd env set EXISTING_DNS_ZONE_OPENAI       "$BASE/privatelink.openai.azure.com"
# azd env set EXISTING_DNS_ZONE_KEYVAULT     "$BASE/privatelink.vaultcore.azure.net"
# azd env set EXISTING_DNS_ZONE_MONITOR      "$BASE/privatelink.monitor.azure.com"
# azd env set EXISTING_DNS_ZONE_EVENTHUB     "$BASE/privatelink.servicebus.windows.net"
# azd env set EXISTING_DNS_ZONE_COSMOSDB     "$BASE/privatelink.documents.azure.com"
# azd env set EXISTING_DNS_ZONE_STORAGE_BLOB "$BASE/privatelink.blob.core.windows.net"
# azd env set EXISTING_DNS_ZONE_STORAGE_FILE "$BASE/privatelink.file.core.windows.net"
# azd env set EXISTING_DNS_ZONE_STORAGE_TABLE "$BASE/privatelink.table.core.windows.net"
# azd env set EXISTING_DNS_ZONE_STORAGE_QUEUE "$BASE/privatelink.queue.core.windows.net"
# azd env set EXISTING_DNS_ZONE_COGNITIVE    "$BASE/privatelink.cognitiveservices.azure.com"
# azd env set EXISTING_DNS_ZONE_APIM         "$BASE/privatelink.azure-api.net"
# azd env set EXISTING_DNS_ZONE_AI_SERVICES  "$BASE/privatelink.services.ai.azure.com"
# azd env set EXISTING_DNS_ZONE_REDIS        "$BASE/privatelink.redis.azure.net"

# --- Log Analytics (default greenfield; switch to BYO with enterprise-baseline patterns) ---
USE_EXISTING_LOG_ANALYTICS=false

# --- Backend services: ALL PRIVATE ---
COSMOS_DB_PUBLIC_ACCESS=Disabled
AI_FOUNDRY_EXTERNAL_NETWORK_ACCESS=Disabled
KEY_VAULT_EXTERNAL_NETWORK_ACCESS=Disabled
REDIS_PUBLIC_NETWORK_ACCESS=Disabled
EVENTHUB_NETWORK_ACCESS=Disabled
# ^^ Event Hub Disabled requires Event Hub Premium SKU.

# --- Capacity ---
COSMOS_DB_RUS=400
EVENTHUB_CAPACITY=1
LOGIC_APPS_SKU_CAPACITY_UNITS=1

# --- Feature flags: production posture ---
ENABLE_PII_REDACTION=true
ENABLE_AI_MODEL_INFERENCE=true
ENABLE_OPENAI_REALTIME=true
ENABLE_UNIFIED_AI_API=true
ENABLE_MANAGED_REDIS=true
ENABLE_API_CENTER=true
ENABLE_AZURE_AI_SEARCH=false
ENABLE_DOCUMENT_INTELLIGENCE=false

# --- Auth: enable JWT post-deploy via upstream entra-id-setup/setup.ps1 ---
AZURE_ENTRA_AUTH=false

# --- Dashboards ---
CREATE_DASHBOARDS=true

# --- SKUs ---
APIC_SKU=Free
KEY_VAULT_SKU_NAME=standard
REDIS_SKU_NAME=Balanced_B1
REDIS_SKU_CAPACITY=1

# ============================================================================
# Spoke-side wiring (NOT done by this profile — happens in the spoke deploy)
# ============================================================================
#
# After this hub deploy succeeds:
#
# 1. Deploy spoke VNet with `foundry-vnet-deploy` skill (or your own
#    Foundry-VNet bicep). Spoke VNet should be in a DIFFERENT address
#    space (e.g., 10.171.0.0/24) to allow peering.
#
# 2. Create bidirectional VNet peering between hub VNet and spoke VNet.
#
# 3. Link `privatelink.azure-api.net` Private DNS Zone to the SPOKE VNet
#    (so spoke agents resolve apim-xxx.azure-api.net to the private IP).
#    The `apim-dns-zone-link.bicep` module from `foundry-vnet-deploy`
#    automates this.
#
# 4. Create the per-team Access Contract via `citadel-spoke-onboarding`.
