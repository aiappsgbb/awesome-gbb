# ============================================================================
# enterprise-baseline.env — production-grade Citadel Governance Hub
# ============================================================================
#
# Use case: this is the hub you'd run in production for an org with
# multi-team Foundry consumption. Production-tier APIM, all backend
# services on private endpoints, BYO Log Analytics so traces flow into
# the central observability landing zone.
#
# What you get:
#   - APIM Standard v2 (production-grade, SLA-backed)
#   - Public APIM gateway (set APIM_V2_PUBLIC_NETWORK_ACCESS=false to
#     go fully private — but then you also need a self-hosted gateway
#     or VPN for spoke testing)
#   - Greenfield VNet (override with USE_EXISTING_VNET=true if you want
#     to peer to an existing landing zone — see vnet-isolated profile)
#   - All backend services PRIVATE (Cosmos, Foundry, KV, Redis private endpoints)
#   - BYO Log Analytics (set EXISTING_LOG_ANALYTICS_* below)
#   - 2× Foundry instances (sweden + east-us-2)
#   - Managed Redis (semantic caching)
#   - API Center enabled (catalog discovery)
#
# Ballpark monthly cost: $800-2,500 with moderate usage (APIM Standard v2
# is the main fixed cost; Foundry token burn dominates above moderate
# usage).
#
# REQUIRED before applying:
#   azd env set EXISTING_LOG_ANALYTICS_NAME            "log-central-prod"
#   azd env set EXISTING_LOG_ANALYTICS_RG              "rg-observability-prod"
#   azd env set EXISTING_LOG_ANALYTICS_SUBSCRIPTION_ID "<central-sub-id>"
#
# Apply: see SKILL.md § 5 Path B
# ============================================================================

# --- Basics ---
AZURE_LOCATION=swedencentral
APIC_LOCATION=swedencentral

# --- APIM (Standard v2 = production) ---
APIM_SKU=StandardV2
APIM_SKU_UNITS=1
APIM_NETWORK_TYPE=External
APIM_V2_USE_PRIVATE_ENDPOINT=true
APIM_V2_PUBLIC_NETWORK_ACCESS=true
# ^^ Set to `false` for fully-private APIM (requires VPN or self-hosted
# gateway for spoke testing). Production posture is `false`.

# --- Networking: greenfield (override for landing zone — see vnet-isolated profile) ---
USE_EXISTING_VNET=false
VNET_ADDRESS_PREFIX=10.170.0.0/24

# --- Log Analytics: BYO (REQUIRED — see header for env-set commands) ---
USE_EXISTING_LOG_ANALYTICS=true
# EXISTING_LOG_ANALYTICS_NAME / RG / SUBSCRIPTION_ID set separately at
# the call site — they're org-specific, not safe to bake into the profile

# --- Backend services: ALL PRIVATE ---
COSMOS_DB_PUBLIC_ACCESS=Disabled
AI_FOUNDRY_EXTERNAL_NETWORK_ACCESS=Disabled
KEY_VAULT_EXTERNAL_NETWORK_ACCESS=Disabled
REDIS_PUBLIC_NETWORK_ACCESS=Disabled
EVENTHUB_NETWORK_ACCESS=Enabled
# ^^ Event Hub stays public by default in upstream; set Disabled if you
# need it private (requires Event Hub Premium SKU).

# --- Capacity (production baseline) ---
COSMOS_DB_RUS=400
EVENTHUB_CAPACITY=1
LOGIC_APPS_SKU_CAPACITY_UNITS=1

# --- Feature flags: production posture ---
ENABLE_PII_REDACTION=true
ENABLE_AI_MODEL_INFERENCE=true
ENABLE_OPENAI_REALTIME=true
ENABLE_UNIFIED_AI_API=true
ENABLE_MANAGED_REDIS=true
ENABLE_API_CENTER=true
ENABLE_AZURE_AI_SEARCH=false
ENABLE_DOCUMENT_INTELLIGENCE=false

# --- Auth: enable JWT post-deploy via upstream entra-id-setup/setup.ps1 ---
AZURE_ENTRA_AUTH=false
# ^^ Set to `true` after running `bicep/infra/entra-id-setup/setup.ps1`
# (creates app registration + populates AZURE_TENANT_ID, AZURE_CLIENT_ID,
# AZURE_AUDIENCE, ENTRA_CLIENT_SECRET azd env vars).

# --- Dashboards: enable (production observability story) ---
CREATE_DASHBOARDS=true

# --- SKUs ---
APIC_SKU=Free
KEY_VAULT_SKU_NAME=standard
REDIS_SKU_NAME=Balanced_B1
REDIS_SKU_CAPACITY=1

# --- Tagging hint (per azd-patterns skill) ---
# Set additional cost-allocation tags via:
#   azd env set AZURE_TAGS '{"costCenter":"<cc>","owner":"<email>","environment":"prod"}'
# `SecurityControl: Ignore` is already in upstream main.bicepparam.
