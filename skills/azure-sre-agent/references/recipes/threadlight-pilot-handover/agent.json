{
  "_scenario": "threadlight-pilot-handover",
  "_description": "SRE Agent pre-wired for the Threadlight pilot handover — webhook-triggered incident triage on ACA pipeline exceptions.",
  "_prerequisites": [
    "Azure subscription with Microsoft.App RP registered",
    "A Threadlight pilot deployed (threadlight-deploy)",
    "The pilot's App Insights resource ID"
  ],
  "_prompts": {
    "agentName": {
      "ask": "Agent name",
      "default": "sre-threadlight-pilot"
    },
    "resourceGroup": {
      "ask": "Resource group for the agent",
      "default": "rg-sre-threadlight-pilot"
    },
    "location": {
      "ask": "Region",
      "options": ["eastus2", "swedencentral", "uksouth", "australiaeast"],
      "required": true
    },
    "targetRGs": {
      "ask": "Resource groups to monitor (the Threadlight pilot's RG)",
      "required": true
    },
    "threadlightAppInsightsId": {
      "ask": "ARM ID of the Threadlight pilot's App Insights resource",
      "required": true
    },
    "threadlightLawId": {
      "ask": "ARM ID of the Threadlight pilot's Log Analytics workspace (defaults to AppIn's LAW)",
      "default": ""
    },
    "threadlightAcaEnvName": {
      "ask": "ACA environment name used by the pilot",
      "required": true
    },
    "existingUamiId": {
      "ask": "Existing UAMI resource ID (leave blank to create new)",
      "default": ""
    }
  },
  "identity": {
    "agentName": "{{agentName}}",
    "resourceGroup": "{{resourceGroup}}",
    "subscription": "",
    "location": "{{location}}",
    "targetResourceGroups": "{{targetRGs}}"
  },
  "access": {
    "accessLevel": "Low",
    "actionMode": "Review"
  },
  "upgradeChannel": "Preview",
  "defaultModelProvider": "Azure OpenAI",
  "monthlyAgentUnitLimit": 10000,
  "tags": {
    "gbb-recipe": "threadlight-pilot-handover",
    "gbb-source": "aiappsgbb/awesome-gbb/azure-sre-agent"
  },
  "toggles": {
    "enableAppInsightsConnector": true,
    "appInsightsResourceId": "{{threadlightAppInsightsId}}",
    "enableLogAnalyticsConnector": true,
    "lawResourceId": "{{threadlightLawId}}",
    "enableWebhookBridge": true
  },
  "existingUamiId": "{{existingUamiId}}",
  "existingAgentAppInsightsId": "{{threadlightAppInsightsId}}"
}
