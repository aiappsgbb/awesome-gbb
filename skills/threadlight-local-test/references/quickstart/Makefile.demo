# Drop-in Makefile for a Threadlight PoC — Pattern 0 (Quickstart).
#
# Rename to `Makefile` (or include it from one) in the PoC root, then:
#   make demo-check    # wire + 1 tool call, no UI, prints layout summary
#   make demo          # launch Streamlit on http://localhost:8501
#   make demo-pump     # launch with the prompt simulator pre-loaded
#
# `uv` is recommended; fall back to plain pip if not installed.

PY ?= python
UV ?= uv

# --- env handling ---------------------------------------------------------
ENV_FILE ?= .env.local
ifneq ("$(wildcard $(ENV_FILE))","")
    include $(ENV_FILE)
    export
endif

# --- targets --------------------------------------------------------------
.PHONY: demo demo-check demo-info demo-pump demo-install demo-clean

demo-install:
	@command -v $(UV) >/dev/null 2>&1 \
		&& $(UV) pip install -e references/quickstart \
		|| $(PY) -m pip install -e references/quickstart

demo-info:
	$(PY) -m threadlight_quickstart --info

demo-check:
	$(PY) -m threadlight_quickstart --check

demo:
	$(PY) -m threadlight_quickstart

demo-pump:
	$(PY) -m threadlight_quickstart --simulator

demo-clean:
	rm -rf .quickstart-cache __pycache__
