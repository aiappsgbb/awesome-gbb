# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.*
# Allow committed template / example env files (sources of truth + plugin copies)
!**/.env.sample
!**/.env.example
!**/.env.local.example
!**/.env.ci.example

# Node (if tooling is added later)
node_modules/

# Python (if tooling is added later)
__pycache__/
*.pyc
.venv/

# local upload artifacts (cowork zips)
skills/*.zip

.zava-audit/

# CI fixture scratch dirs (Pattern 20 — AGENTS.md § 9.7).
# The Copilot CLI shell-tool permission gate rejects writes outside
# $GITHUB_WORKSPACE, so Azure fixtures scaffold azd projects + Bicep
# files under <workspace>/.scratch/<unique-name>/ instead of /tmp.
.scratch/

# Upstream-pin live-validation working dir (AGENTS.md § 9.5).
# `validation.script` in references/upstream-pin.md clones the upstream
# repo here (default WORKDIR=$ROOT_DIR/.upstream-pin-work/<skill>) to
# diff/build against the pinned SHA. Transient — never commit the clone.
.upstream-pin-work/
